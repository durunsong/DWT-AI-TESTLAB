{
  "name": "ai-e2e-test-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/kill-dev-ports.mjs",
    "dev": "pnpm --parallel --filter @ai-e2e/server --filter @ai-e2e/web dev",
    "dev:stop": "node scripts/kill-dev-ports.mjs",
    "build": "pnpm -r build",
    "build:local": "pnpm -r --if-present build:local",
    "build:dev": "pnpm -r --if-present build:dev",
    "build:sit": "pnpm -r --if-present build:sit",
    "build:prod": "pnpm -r --if-present build:prod",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
