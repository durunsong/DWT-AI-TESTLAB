{
  "name": "@ai-e2e/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:local": "tsc -p tsconfig.json --noEmit && vite build --mode local",
    "build:dev": "tsc -p tsconfig.json --noEmit && vite build --mode dev",
    "build:sit": "tsc -p tsconfig.json --noEmit && vite build --mode sit",
    "build:prod": "tsc -p tsconfig.json --noEmit && vite build --mode prod",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@monaco-editor/react": "^4.7.0",
    "@vitejs/plugin-react": "^6.0.2",
    "antd": "^6.4.3",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^8.0.13",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0"
  }
}
