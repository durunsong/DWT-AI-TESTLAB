{
  "name": "@ai-e2e/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 4301 --strictPort",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:local": "tsc -p tsconfig.json --noEmit && vite build --mode local",
    "build:dev": "tsc -p tsconfig.json --noEmit && vite build --mode dev",
    "build:sit": "tsc -p tsconfig.json --noEmit && vite build --mode sit",
    "build:prod": "tsc -p tsconfig.json --noEmit && vite build --mode prod",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "@monaco-editor/react": "^4.6.0",
    "@vitejs/plugin-react": "^4.2.1",
    "antd": "^5.17.3",
    "axios": "^1.7.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.11",
    "monaco-editor": "^0.49.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^5.2.11",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "tailwindcss": "^4.3.0"
  }
}
